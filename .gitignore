# Dependencies
node_modules/

# Build artifacts
dist/

# Data (contains real user financial data — never commit)
data/*.sqlite
data/*.db
# Enable Banking session/consent state (bearer session id) — never commit
data/eb-session.json
data/eb-pending.json
# Enable Banking app-managed encryption key + config — never commit
data/eb-master.key
data/eb-config.json

# Database backups (make backup) — contain real financial data
backups/

# Local IDE / Claude Code settings
.claude/

# Environment files
.env
.env.local
.env.*.local

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Playwright artifacts
.playwright-mcp/

# Local screenshots from verification / design iterations are scratch and
# ignored — except the README images, which are tracked.
screenshots/*
!screenshots/dashboard.png
!screenshots/budget.png
!screenshots/assets.png
/*.png
/*-snapshot.md
/*-refs.md

# Payslip PDFs — parsed client-side, never stored/committed
*.pdf

# Private keys / certs (e.g. Enable Banking app RSA key) — never commit
*.pem
*.key

# Enable Banking extractor: real financial data + local self-signed cert
scripts/enable-banking/out/
scripts/enable-banking/.cert/
